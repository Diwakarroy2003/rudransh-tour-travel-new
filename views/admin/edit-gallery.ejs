<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>

<title>Edit Gallery</title>

<link
rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
/>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
min-height:100vh;
padding:30px;
background:
linear-gradient(rgba(6,36,62,.94),rgba(6,36,62,.94)),
url("/assets/img/banner1.jpg") center/cover no-repeat;
display:flex;
justify-content:center;
align-items:center;
}

.wrapper{
width:100%;
max-width:520px;
}

.topbar{
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:20px;
}

.topbar h1{
color:#fff;
font-size:26px;
}

.back-btn{
background:#fff;
color:#0d6efd;
text-decoration:none;
padding:10px 16px;
border-radius:8px;
font-weight:bold;
}

.card{
background:rgba(255,255,255,.12);
border-radius:18px;
padding:28px;
backdrop-filter:blur(12px);
box-shadow:0 10px 25px rgba(0,0,0,.25);
}

label{
display:block;
margin-bottom:10px;
color:#fff;
font-weight:bold;
}

input{
width:100%;
padding:12px;
border:none;
border-radius:10px;
margin-bottom:18px;
font-size:15px;
}

button{
width:100%;
padding:13px;
border:none;
border-radius:10px;
background:linear-gradient(135deg,#0d6efd,#42b3ff);
color:#fff;
font-size:16px;
font-weight:bold;
cursor:pointer;
}

button:hover{
opacity:.95;
}
</style>
</head>

<body>

<div class="wrapper">

<div class="topbar">

<h1>Edit Gallery</h1>

<a
href="/admin/gallery"
class="back-btn"
>
<i class="fa-solid fa-arrow-left"></i>
Back
</a>

</div>

<form
action="/admin/gallery/update/<%= item._id %>"
method="POST"
class="card"
>

<label>Image Title</label>

<input
type="text"
name="title"
value="<%= item.title %>"
required
>

<button type="submit">

<i class="fa-solid fa-floppy-disk"></i>

Update Title

</button>

</form>

</div>

</body>
</html>