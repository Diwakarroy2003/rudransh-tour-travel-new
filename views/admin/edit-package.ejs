<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>

<title>Edit Package</title>

<link
rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
/>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
min-height:100vh;
padding:30px;
background:
linear-gradient(rgba(6,36,62,.94),rgba(6,36,62,.94)),
url("/assets/img/banner1.jpg") center/cover no-repeat;
display:flex;
justify-content:center;
align-items:center;
}

.wrapper{
width:100%;
max-width:650px;
}

.topbar{
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:20px;
}

.topbar h1{
color:#fff;
}

.back-btn{
background:#fff;
color:#0d6efd;
padding:10px 16px;
border-radius:8px;
font-weight:bold;
text-decoration:none;
}

.card{
background:rgba(255,255,255,.12);
padding:28px;
border-radius:18px;
backdrop-filter:blur(12px);
}

label{
display:block;
color:#fff;
font-weight:bold;
margin-bottom:8px;
}

input,
textarea{
width:100%;
padding:12px;
border:none;
border-radius:10px;
margin-bottom:14px;
font-size:15px;
}

textarea{
min-height:120px;
resize:vertical;
}

.preview{
width:180px;
border-radius:10px;
margin-bottom:14px;
display:block;
}

button{
width:100%;
padding:13px;
border:none;
border-radius:10px;
background:linear-gradient(135deg,#0d6efd,#42b3ff);
color:#fff;
font-size:16px;
font-weight:bold;
cursor:pointer;
}
</style>
</head>

<body>

<div class="wrapper">

<div class="topbar">

<h1>Edit Package</h1>

<a
href="/admin/package"
class="back-btn"
>
<i class="fa-solid fa-arrow-left"></i>
Back
</a>

</div>

<form
action="/admin/package/update/<%= package._id %>"
method="POST"
enctype="multipart/form-data"
class="card"
>

<input
type="text"
name="title"
value="<%= package.title %>"
required
>

<input
type="text"
name="price"
value="<%= package.price %>"
required
>

<label>Current Image</label>

<img
src="/uploads/<%= package.image %>"
alt=""
class="preview"
>

<input
type="file"
name="image"
accept="image/*"
>

<textarea
name="description"
required
><%= package.description %></textarea>

<button type="submit">

<i class="fa-solid fa-floppy-disk"></i>

Update Package

</button>

</form>

</div>

</body>
</html>