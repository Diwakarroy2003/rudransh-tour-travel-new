<script>
  const observer = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.1 });
  document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
</script>






<script>
    function filterCards(btn, tag) {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
 
      const dhamSections = document.querySelectorAll('.dham-section');
 
      if (tag === 'all') {
        dhamSections.forEach(s => s.style.display = 'block');
        document.querySelectorAll('.hotel-card').forEach(c => {
          c.style.display = '';
          c.style.animation = 'none';
          void c.offsetWidth;
          c.style.animation = 'fadeUp 0.5s forwards';
        });
        return;
      }
 
      // Dham filter
      if (['kedarnath','badrinath','gangotri','yamunotri'].includes(tag)) {
        dhamSections.forEach(s => {
          s.style.display = s.dataset.dham === tag ? 'block' : 'none';
        });
        document.querySelectorAll('.hotel-card').forEach(c => { c.style.display = ''; });
        return;
      }
 
      // Type filter (luxury/budget/premium)
      dhamSections.forEach(s => s.style.display = 'block');
      document.querySelectorAll('.hotel-card').forEach(c => {
        const tags = (c.dataset.tags || '').split(' ');
        if (tags.includes(tag)) {
          c.style.display = '';
          c.style.animation = 'none';
          void c.offsetWidth;
          c.style.animation = 'fadeUp 0.5s forwards';
        } else {
          c.style.display = 'none';
        }
      });
    }
 
    // Wishlist toggle
    document.querySelectorAll('.card-wish').forEach(btn => {
      btn.addEventListener('click', () => {
        const icon = btn.querySelector('i');
        icon.classList.toggle('far');
        icon.classList.toggle('fas');
        btn.style.transform = 'scale(1.3)';
        setTimeout(() => btn.style.transform = '', 200);
      });
    });
  </script>

