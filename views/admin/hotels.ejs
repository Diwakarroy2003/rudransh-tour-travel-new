    <!-- header Section Start-->
<div class="top-offer-text-slider-section">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="top-offer-text-slider-wrap">
                        <div class="slider-btn top-offer-text-slider-prev">
