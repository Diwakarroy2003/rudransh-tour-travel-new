  <style>


    :root {
      --blue-deep:   #0b1f4b;
      --blue-mid:    #1a3a7c;
      --blue-bright: #2256c7;
      --blue-light:  #3b82f6;
     
      --white:       #ffffff;
      --off-white:   #f8f7f4;
      --grey-light:  #e8e4dc;
      --grey-text:   #6b6560;
      --text-dark:   #1a1510;
      --shadow-blue: 0 20px 60px rgba(11,31,75,0.18);
      --shadow-gold: 0 8px 30px rgba(201,168,76,0.25);
    }


    * {
  font-family: "Poppins", sans-serif !important;
}
 
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
 
    html { scroll-behavior: smooth; }
 
    body {
      font-family: 'Crimson Pro', Georgia, serif;
      background: var(--off-white);
      color: var(--text-dark);
      overflow-x: hidden;
    }
 
    /* ─── HERO ─── */
    .hero {
      position: relative;
      height: 72vh; min-height: 520px;
      background: linear-gradient(160deg, #1ab0f0 0%, #0da8ee 40%, #0b9fea 75%, #18abf0 100%);
      display: flex; align-items: center; justify-content: center;
      text-align: center;
      overflow: hidden;
      margin-top: 0;
    }
 
    /* Subtle mandala BG */
     .hero::before {
  content: "";
  position: absolute;
  inset: 0;
  background: 
    linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)),
    url("assets/img/banner1.jpg") center/cover no-repeat;
  z-index: 0;
}
 
    .hero-content { position: relative; z-index: 2; padding: 0 1rem; }
    .hero-eyebrow {
      font-family: 'Cinzel', serif;
      color: var(--gold);
      font-size: 0.75rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      margin-bottom: 1.2rem;
      display: flex; align-items: center; justify-content: center; gap: 1rem;
    }
    .hero-eyebrow::before, .hero-eyebrow::after {
      content: '';
      display: block; width: 50px; height: 1px;
      background: linear-gradient(90deg, transparent, var(--gold));
    }
    .hero-eyebrow::after { background: linear-gradient(90deg, var(--gold), transparent); }
 
    .hero h1 {
      font-family: 'Cinzel Decorative', serif;
      color: var(--white);
      font-size: clamp(2.2rem, 5.5vw, 4rem);
      line-height: 1.15;
      margin-bottom: 0.5rem;
      text-shadow: 0 4px 30px rgba(0,0,0,0.4);
    }
    .hero h1 span { color: var(--gold-light); }
 
    .hero-subtitle {
      color: rgba(255,255,255,0.7);
      font-size: clamp(1rem, 2vw, 1.25rem);
      font-style: italic;
      margin-bottom: 2rem;
      font-weight: 300;
    }
 
    .hero-stats {
      display: flex; align-items: center; justify-content: center; gap: 2.5rem;
      flex-wrap: wrap;
    }
    .stat {
      text-align: center;
    }
    .stat-num {
      font-family: 'Cinzel', serif;
      font-size: 1.8rem;
      font-weight: 700;
      color: var(--gold);
      line-height: 1;
    }
    .stat-label {
      font-size: 0.78rem;
      color: rgba(255,255,255,0.6);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      font-family: 'Cinzel', serif;
      margin-top: 0.2rem;
    }
    .stat-divider { width: 1px; height: 40px; background: rgba(201,168,76,0.35); }
 
    /* scroll arrow */
    .scroll-down {
      position: absolute; bottom: 28px; left: 50%; transform: translateX(-50%);
      color: rgba(255,255,255,0.45);
      font-size: 1.3rem;
      animation: bounce 2s infinite;
      cursor: pointer;
    }
    @keyframes bounce {
      0%,100%{ transform: translateX(-50%) translateY(0); }
      50%{ transform: translateX(-50%) translateY(8px); }
    }
 
    /* ─── SECTION WRAPPER ─── */
    .section { padding: 90px 5%; }
    .section-header { text-align: center; margin-bottom: 60px; }
    .section-eyebrow {
      font-family: 'Cinzel', serif;
      font-size: 0.72rem;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.8rem;
      display: flex; align-items: center; justify-content: center; gap: 0.8rem;
    }
    .section-eyebrow::before,.section-eyebrow::after {
      content:''; width:36px; height:1px; background:var(--gold); opacity:.5;
    }
    .section-title {
      font-family: 'Cinzel Decorative', serif;
      font-size: clamp(1.6rem, 3.5vw, 2.5rem);
      color: var(--blue-deep);
      margin-bottom: 1rem;
    }
    .section-desc {
      color: var(--grey-text);
      font-size: 1.1rem;
      max-width: 600px;
      margin: 0 auto;
      font-style: italic;
      font-weight: 300;
    }
 
    /* ─── FILTER TABS ─── */
    .filter-bar {
      display: flex; flex-wrap: wrap; gap: 0.7rem;
      justify-content: center; margin-bottom: 56px;
    }
    .filter-btn {
      font-family: 'Cinzel', serif;
      font-size: 0.72rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      padding: 0.6rem 1.5rem;
      border: 1.5px solid var(--grey-light);
      background: var(--white);
      color: var(--grey-text);
      border-radius: 2px;
      cursor: pointer;
      transition: all 0.25s;
    }
    .filter-btn:hover { border-color: var(--blue-light); color: var(--blue-mid); }
    .filter-btn.active {
      background: var(--blue-deep);
      border-color: var(--blue-deep);
      color: var(--gold-light);
    }
 
    /* ─── HOTELS GRID ─── */
    .hotels-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
      gap: 2rem;
      max-width: 1300px;
      margin: 0 auto;
    }
 
    /* ─── HOTEL CARD ─── */
    .hotel-card {
      background: var(--white);
      border-radius: 4px;
      overflow: hidden;
      box-shadow: 0 4px 20px rgba(11,31,75,0.08);
      transition: box-shadow 0.35s, transform 0.35s;
      position: relative;
    }
    .hotel-card:hover {
      box-shadow: var(--shadow-blue);
      transform: translateY(-6px);
    }
 
    /* image wrapper */
    .card-img-wrap {
      position: relative;
      height: 240px;
      overflow: hidden;
    }
    .card-img-wrap img {
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94), filter 0.4s;
      filter: brightness(0.9);
    }
    .hotel-card:hover .card-img-wrap img {
      transform: scale(1.1);
      filter: brightness(1);
    }
 
    /* image overlay on hover */
    .card-img-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(180deg, transparent 30%, rgba(11,31,75,0.65) 100%);
      opacity: 0;
      transition: opacity 0.4s;
      display: flex; align-items: flex-end; padding: 1.2rem;
    }
    .hotel-card:hover .card-img-overlay { opacity: 1; }
    .overlay-view-btn {
      font-family: 'Cinzel', serif;
      font-size: 0.68rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--white);
      border: 1px solid rgba(255,255,255,0.6);
      padding: 0.45rem 1.1rem;
      border-radius: 2px;
      cursor: pointer;
      transition: background 0.2s, border-color 0.2s;
      background: rgba(255,255,255,0.08);
      backdrop-filter: blur(4px);
    }
    .overlay-view-btn:hover { background: rgba(255,255,255,0.2); border-color: var(--gold); color: var(--gold-light); }
 
    /* badge */
    .card-badge {
      position: absolute; top: 16px; left: 16px;
      font-family: 'Cinzel', serif;
      font-size: 0.62rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      padding: 0.3rem 0.8rem;
      border-radius: 2px;
      font-weight: 700;
      z-index: 2;
    }
    .badge-luxury { background: var(--gold); color: var(--blue-deep); }
    .badge-budget { background: var(--blue-deep); color: var(--gold-light); }
    .badge-premium { background: #2d6a4f; color: #b7e4c7; }
    .badge-new { background: #7b2d8b; color: #e9d5f5; }
 
    /* wishlist icon */
    .card-wish {
      position: absolute; top: 14px; right: 14px;
      width: 34px; height: 34px;
      background: rgba(255,255,255,0.92);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer;
      z-index: 2;
      transition: background 0.2s, transform 0.2s;
      box-shadow: 0 2px 8px rgba(0,0,0,0.15);
    }
    .card-wish:hover { background: var(--white); transform: scale(1.12); }
    .card-wish i { font-size: 0.85rem; color: #d9534f; }
 
    /* rating ribbon */
    .card-rating {
      position: absolute; bottom: 0; right: 0;
      background: var(--blue-deep);
      color: var(--gold-light);
      font-family: 'Cinzel', serif;
      font-size: 0.85rem;
      font-weight: 700;
      padding: 0.3rem 0.7rem;
      border-top-left-radius: 4px;
      display: flex; align-items: center; gap: 0.3rem;
    }
    .card-rating i { font-size: 0.65rem; color: var(--gold); }
 
    /* card body */
    .card-body { padding: 1.4rem 1.4rem 1rem; }
    .card-dham {
      font-family: 'Cinzel', serif;
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--blue-bright);
      margin-bottom: 0.4rem;
      display: flex; align-items: center; gap: 0.4rem;
    }
    .card-dham i { font-size: 0.6rem; }
    .card-name {
      font-family: 'Cinzel', serif;
      font-size: 1.15rem;
      font-weight: 700;
      color: var(--blue-deep);
      margin-bottom: 0.4rem;
      line-height: 1.25;
    }
    .card-location {
      font-size: 0.9rem;
      color: var(--grey-text);
      margin-bottom: 0.9rem;
      display: flex; align-items: center; gap: 0.35rem;
    }
    .card-location i { font-size: 0.75rem; color: var(--gold); }
 
    /* amenities */
    .card-amenities {
      display: flex; flex-wrap: wrap; gap: 0.5rem;
      margin-bottom: 1.1rem;
    }
    .amenity {
      font-size: 0.75rem;
      color: var(--grey-text);
      background: var(--off-white);
      border: 1px solid var(--grey-light);
      padding: 0.25rem 0.6rem;
      border-radius: 20px;
      display: flex; align-items: center; gap: 0.3rem;
    }
    .amenity i { font-size: 0.65rem; color: var(--blue-light); }
 
    /* card footer */
    .card-footer {
      border-top: 1px solid var(--grey-light);
      padding: 1rem 1.4rem;
      display: flex; align-items: center; justify-content: space-between;
    }
    .price-wrap {}
    .price-from {
      font-size: 0.72rem;
      color: var(--grey-text);
      font-family: 'Cinzel', serif;
      letter-spacing: 0.05em;
    }
    .price-num {
      font-family: 'Cinzel', serif;
      font-size: 1.3rem;
      font-weight: 700;
      color: var(--blue-deep);
      line-height: 1;
    }
    .price-num span { font-size: 0.8rem; color: var(--grey-text); font-weight: 400; }
    .book-btn {
      font-family: 'Cinzel', serif;
      font-size: 0.68rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      background: var(--grey-text);
      color: var(--gold-light);
      border: none;
      padding: 0.65rem 1.3rem;
      border-radius: 2px;
      cursor: pointer;
      transition: background 0.25s, transform 0.2s, box-shadow 0.25s;
    }
    .book-btn:hover {
      background: var(--blue-bright);
      transform: translateY(-1px);
      box-shadow: 0 4px 14px rgba(34,86,199,0.35);
    }
 
    /* ─── FEATURED (wide card) ─── */
    .hotel-card.featured {
      grid-column: 1 / -1;
      display: grid;
      grid-template-columns: 1.2fr 1fr;
    }
    .hotel-card.featured .card-img-wrap { height: 100%; min-height: 300px; }
    .hotel-card.featured .card-right { display: flex; flex-direction: column; }
    .hotel-card.featured .card-body { flex: 1; }
 
    /* ─── DHAM SECTIONS with dividers ─── */
    .dham-section { margin-bottom: 80px; }
    .dham-header {
      display: flex; align-items: center; gap: 1.2rem;
      margin-bottom: 2.2rem;
    }
    .dham-icon {
      width: 54px; height: 54px;
      background: var(--blue-deep);
      border-radius: 2px;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .dham-icon i { font-size: 1.4rem; color: var(--gold); }
    .dham-title {
      font-family: 'Cinzel', serif;
      font-size: 1.3rem;
      font-weight: 700;
      color: var(--blue-deep);
    }
    .dham-altitude {
      font-size: 0.85rem;
      color: var(--grey-text);
      font-style: italic;
    }
    .dham-line {
      flex: 1;
      height: 1px;
      background: linear-gradient(90deg, var(--grey-light), transparent);
    }
 
    /* ─── PERKS STRIP ─── */
    .perks-strip {
      background: var(--blue-deep);
      padding: 50px 5%;
    }
    .perks-inner {
      max-width: 1100px; margin: 0 auto;
      display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 2rem;
    }
    .perk {
      display: flex; flex-direction: column; align-items: center;
      text-align: center; gap: 0.8rem;
    }
    .perk-icon {
      width: 56px; height: 56px;
      border: 1.5px solid rgba(201,168,76,0.4);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
    }
    .perk-icon i { font-size: 1.3rem; color: var(--gold); }
    .perk-title {
      font-family: 'Cinzel', serif;
      font-size: 0.85rem;
      color: var(--white);
      font-weight: 600;
      letter-spacing: 0.05em;
    }
    .perk-desc { font-size: 0.88rem; color: rgba(255,255,255,0.55); line-height: 1.5; }
 
    /* ─── TESTIMONIALS ─── */
    .testimonials-bg { background: var(--off-white); }
    .testimonials-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 1.6rem;
      max-width: 1100px; margin: 0 auto;
    }
    .testi-card {
      background: var(--white);
      border-radius: 4px;
      padding: 1.8rem;
      box-shadow: 0 2px 14px rgba(11,31,75,0.07);
      border-top: 3px solid var(--gold);
      position: relative;
    }
    .testi-quote {
      font-size: 3rem;
      color: var(--gold-pale);
      font-family: Georgia, serif;
      line-height: 1;
      position: absolute;
      top: 10px; right: 18px;
    }
    .testi-stars { color: var(--gold); font-size: 0.85rem; margin-bottom: 0.9rem; }
    .testi-text {
      font-size: 1rem;
      line-height: 1.7;
      color: #444;
      font-style: italic;
      margin-bottom: 1.2rem;
    }
    .testi-author { display: flex; align-items: center; gap: 0.8rem; }
    .testi-avatar {
      width: 42px; height: 42px; border-radius: 50%;
      background: var(--blue-deep);
      display: flex; align-items: center; justify-content: center;
      font-family: 'Cinzel', serif;
      color: var(--gold);
      font-size: 0.95rem;
      font-weight: 700;
      flex-shrink: 0;
    }
    .testi-name { font-family: 'Cinzel', serif; font-size: 0.85rem; color: var(--blue-deep); font-weight: 600; }
    .testi-dham { font-size: 0.78rem; color: var(--grey-text); }
 
    /* ─── BOOKING BANNER ─── */
    .booking-banner {
      background: linear-gradient(160deg, #1ab0f0 0%, #0fa3e8 40%, #0d9bde 75%, #18ace9 100%);
      padding: 80px 5%;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .booking-banner::before {
      content: '';
      position: absolute; inset: 0;
      background: radial-gradient(ellipse 60% 80% at 50% 100%, rgba(201,168,76,0.1) 0%, transparent 70%);
    }
    .booking-banner h2 {
      font-family: 'Cinzel Decorative', serif;
      color: var(--white);
      font-size: clamp(1.5rem, 3vw, 2.2rem);
      margin-bottom: 0.8rem;
      position: relative;
    }
    .booking-banner p {
      color: rgba(255,255,255,0.65);
      font-size: 1.1rem;
      font-style: italic;
      margin-bottom: 2.2rem;
      position: relative;
    }
    .banner-btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; position: relative; }
    .btn-gold {
      font-family: 'Cinzel', serif;
      font-size: 0.78rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      background: var(--gold);
      color: var(--blue-deep);
      padding: 0.85rem 2.2rem;
      border-radius: 2px;
      border: none;
      cursor: pointer;
      font-weight: 700;
      transition: background 0.25s, transform 0.2s, box-shadow 0.25s;
    }
    .btn-gold:hover { background: var(--gold-light); transform: translateY(-2px); box-shadow: var(--shadow-gold); }
    .btn-outline {
      font-family: 'Cinzel', serif;
      font-size: 0.78rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      background: transparent;
      color: var(--white);
      padding: 0.85rem 2.2rem;
      border-radius: 2px;
      border: 1.5px solid rgba(255,255,255,0.4);
      cursor: pointer;
      font-weight: 600;
      transition: border-color 0.25s, background 0.25s;
    }
    .btn-outline:hover { border-color: var(--gold); color: var(--gold-light); background: rgba(255,255,255,0.05); }
 
    /* ─── RESPONSIVE ─── */
    @media (max-width: 900px) {
      .hotel-card.featured { grid-template-columns: 1fr; }
      .hotel-card.featured .card-img-wrap { height: 260px; }
      .nav-links { display: none; }
    }
    @media (max-width: 600px) {
      .hero h1 { font-size: 1.9rem; }
      .hero-stats { gap: 1.5rem; }
      .stat-divider { display: none; }
      .section { padding: 60px 4%; }
      .hotels-grid { grid-template-columns: 1fr; }
    }
 
    /* ─── LOAD ANIMATION ─── */
    .hotel-card {
      opacity: 0;
      transform: translateY(24px);
      animation: fadeUp 0.55s forwards;
    }
    @keyframes fadeUp {
      to { opacity: 1; transform: translateY(0); }
    }
    .hotel-card:nth-child(1){ animation-delay: 0.05s; }
    .hotel-card:nth-child(2){ animation-delay: 0.15s; }
    .hotel-card:nth-child(3){ animation-delay: 0.25s; }
    .hotel-card:nth-child(4){ animation-delay: 0.10s; }
    .hotel-card:nth-child(5){ animation-delay: 0.20s; }
    .hotel-card:nth-child(6){ animation-delay: 0.30s; }
  </style>
</head>

<body class="tt-magic-cursor">

    <div id="magic-cursor">
        <div id="ball"></div>
    </div>

    <!-- Back To Top -->
    <div class="progress-wrap">
        <svg class="progress-circle svg-content" width="100%" height="100%" viewBox="-1 -1 102 102">
            <path d="M50,1 a49,49 0 0,1 0,98 a49,49 0 0,1 0,-98"/>
