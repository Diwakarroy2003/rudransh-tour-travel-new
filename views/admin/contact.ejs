          <a href="/" class="header-logo">
            <img src="assets/img/header-logo1.jpg" alt="" />
          </a>
          <div class="main-menu">
            <div
              class="mobile-logo-area d-xl-none d-flex align-items-center justify-content-between"
            >
              <a href="/" class="mobile-logo-wrap">
                <img src="assets/img/header-logo1.jpg" alt="" />
