    <style>
      :root {
        --gold: #60c8f5;
        --gold-light: #b8e8ff;
        --gold-dark: #0d6ebd;
        --deep-brown: #06243e;
        --mid-brown: #0a3a64;
        --warm-cream: #ffffff;
        --off-white: #e0f4ff;
        --rust: #0d6ebd;
        --shadow-gold: rgba(30, 120, 220, 0.3);
      }

      * {
  font-family: "Poppins", sans-serif !important;
}

      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: "Lato", sans-serif;
        background: #ffffff;
        color: var(--warm-cream);
        min-height: 100vh;
        overflow-x: hidden;
      }

      /* ── HERO SECTION ── */
      .hero {
        position: relative;
        min-height: 380px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 80px 20px 60px;
        margin-top: 0;
        overflow: hidden;
      }

   .hero::before {
  content: "";
  position: absolute;
  inset: 0;
  background: 
    linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)),
    url("assets/img/banner1.jpg") center/cover no-repeat;
  z-index: 0;
}

      .hero::after {
        content: "";
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 120px;
        background: linear-gradient(to bottom, transparent, #06243e);
        z-index: 1;
      }

      .hero-content {
        position: relative;
        z-index: 2;
      }

      .brand-badge {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: rgba(255, 255, 255, 0.15);
        border: 1px solid rgba(255, 255, 255, 0.4);
        border-radius: 40px;
        padding: 8px 22px;
        font-family: "Cinzel", serif;
        font-size: 0.78rem;
        letter-spacing: 0.18em;
        color: #ffffff;
        text-transform: uppercase;
        margin-bottom: 20px;
        backdrop-filter: blur(8px);
      }

      .hero h1 {
        font-family: "Cinzel Decorative", cursive;
        font-size: clamp(2rem, 6vw, 3.8rem);
        font-weight: 900;
        line-height: 1.1;
        color: #ffffff;
        -webkit-text-fill-color: #ffffff;
        text-shadow: 0 2px 20px rgba(0, 0, 0, 0.2);
        margin-bottom: 14px;
      }

      .hero-sub {
        font-family: "Cinzel", serif;
        font-size: clamp(0.85rem, 2vw, 1.1rem);
        color: rgba(255, 255, 255, 0.85);
        letter-spacing: 0.12em;
        max-width: 500px;
        margin: 0 auto 28px;
      }

      .divider-ornament {
        display: flex;
        align-items: center;
        gap: 14px;
        justify-content: center;
        margin-bottom: 0;
      }

      .divider-ornament span {
        height: 1px;
        width: 80px;
        background: linear-gradient(to right, transparent, var(--gold));
      }
      .divider-ornament span:last-child {
        background: linear-gradient(to left, transparent, var(--gold));
      }
      .divider-ornament i {
        color: var(--gold);
        font-size: 1.1rem;
      }

      /* ── QUICK CONTACT STRIP ── */
      .quick-strip {
        background: linear-gradient(
          90deg,
          #0d5fa8 0%,
          #1a7dd4 50%,
          #0d5fa8 100%
        );
        padding: 0;
        overflow: hidden;
      }

      .quick-strip-inner {
        max-width: 1100px;
        margin: 0 auto;
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0;
      }

      .quick-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 16px 28px;
        border-right: 1px solid rgba(255, 255, 255, 0.15);
        flex: 1 1 200px;
        min-width: 170px;
        justify-content: center;
        transition: background 0.3s;
        cursor: pointer;
        text-decoration: none;
        color: inherit;
      }
      .quick-item:last-child {
        border-right: none;
      }
      .quick-item:hover {
        background: rgba(255, 255, 255, 0.1);
      }

      .quick-item i {
        font-size: 1.2rem;
        color: var(--gold-light);
      }

      .quick-item-text {
        line-height: 1.3;
      }
      .quick-item-label {
        font-size: 0.68rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.65);
      }
      .quick-item-value {
        font-family: "Cinzel", serif;
        font-size: 0.88rem;
        font-weight: 700;
        color: var(--warm-cream);
      }

      /* ── MAIN CONTENT ── */
      .main {
        max-width: 1200px;
        margin: 0 auto;
        padding: 70px 20px 80px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 50px;
        align-items: start;
      }

      /* ── FORM CARD ── */
      .form-card {
        background: linear-gradient(
          145deg,
          rgba(10, 58, 100, 0.9),
          rgba(6, 36, 62, 0.95)
        );
        border: 1px solid rgba(96, 200, 245, 0.3);
        border-radius: 20px;
        padding: 48px 40px;
        position: relative;
        overflow: hidden;
        box-shadow:
          0 30px 80px rgba(0, 0, 0, 0.5),
          0 0 0 1px rgba(96, 200, 245, 0.1) inset;
      }

      .form-card::before {
        content: "";
        position: absolute;
        top: -60px;
        right: -60px;
        width: 220px;
        height: 220px;
        background: radial-gradient(
          circle,
          rgba(30, 144, 232, 0.15) 0%,
          transparent 70%
        );
        pointer-events: none;
      }

      .section-title {
        font-family: "Cinzel", serif;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--gold-light);
        margin-bottom: 6px;
      }

      .section-subtitle {
        font-size: 0.9rem;
        color: rgba(255, 255, 255, 0.5);
        margin-bottom: 32px;
        letter-spacing: 0.04em;
      }

      .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 18px;
      }

      .form-group {
        margin-bottom: 20px;
        position: relative;
      }

      .form-group label {
        display: block;
        font-size: 0.75rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 8px;
        font-weight: 700;
      }

      .input-wrap {
        position: relative;
      }

      .input-wrap i {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: rgba(96, 200, 245, 0.5);
        font-size: 0.95rem;
        pointer-events: none;
        transition: color 0.3s;
      }

      .input-wrap.textarea-wrap i {
        top: 16px;
        transform: none;
      }

      .form-group input,
      .form-group select,
      .form-group textarea {
        width: 100%;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(96, 200, 245, 0.2);
        border-radius: 10px;
        padding: 13px 14px 13px 40px;
        color: var(--warm-cream);
        font-family: "Lato", sans-serif;
        font-size: 0.95rem;
        outline: none;
        transition:
          border-color 0.3s,
          background 0.3s,
          box-shadow 0.3s;
        -webkit-appearance: none;
      }

      .form-group select option {
        background: var(--mid-brown);
      }

      .form-group input:focus,
      .form-group select:focus,
      .form-group textarea:focus {
        border-color: #2bb5f5;
        background: rgba(30, 144, 232, 0.08);
        box-shadow: 0 0 0 3px rgba(30, 144, 232, 0.15);
      }

      .form-group input:focus + i,
      .form-group select:focus + i,
      .form-group textarea:focus + i {
        color: var(--gold);
      }

      .form-group input::placeholder,
      .form-group textarea::placeholder {
        color: rgba(253, 243, 227, 0.25);
      }

      .form-group textarea {
        resize: vertical;
        min-height: 110px;
      }

      .btn-submit {
        width: 100%;
        padding: 16px;
        background: linear-gradient(135deg, #0d5fa8, #1e90e8, #2bb5f5);
        border: none;
        border-radius: 12px;
        font-family: "Cinzel", serif;
        font-size: 1rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        color: #ffffff;
        cursor: pointer;
        transition: all 0.35s ease;
        box-shadow: 0 6px 30px rgba(30, 144, 232, 0.4);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        margin-top: 8px;
      }

      .btn-submit:hover {
        transform: translateY(-3px);
        box-shadow: 0 12px 40px rgba(30, 144, 232, 0.55);
        background: linear-gradient(135deg, #1e90e8, #2bb5f5, #1e90e8);
      }

      .btn-submit:active {
        transform: translateY(0);
      }

      /* ── INFO PANEL ── */
      .info-panel {
        display: flex;
        flex-direction: column;
        gap: 28px;
      }

      /* Dham single image - fully responsive */
      .dham-mosaic {
        width: 100%;
        aspect-ratio: 16 / 9; /* auto responsive height */
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
      }

      .dham-mosaic img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
      }

      .dham-mosaic img:hover {
        transform: scale(1.06);
      }

      /* Contact info cards */
      .info-cards {
        display: flex;
        flex-direction: column;
        gap: 14px;
      }

      .info-card {
        display: flex;
        align-items: flex-start;
        gap: 16px;
        background: linear-gradient(
          135deg,
          rgba(10, 58, 100, 0.85),
          rgba(6, 36, 62, 0.9)
        );
        border: 1px solid rgba(96, 200, 245, 0.2);
        border-radius: 14px;
        padding: 18px 22px;
        transition:
          border-color 0.3s,
          transform 0.3s,
          box-shadow 0.3s;
        text-decoration: none;
        color: inherit;
      }

      .info-card:hover {
        border-color: #2bb5f5;
        transform: translateX(6px);
        box-shadow: 0 8px 30px rgba(30, 144, 232, 0.2);
      }

      .info-icon {
        width: 46px;
        height: 46px;
        background: linear-gradient(135deg, #0d5fa8, #1e90e8);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: 1.1rem;
        color: #ffffff;
        box-shadow: 0 4px 15px rgba(30, 144, 232, 0.35);
      }

      .info-text {
      }
      .info-label {
        font-size: 0.7rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--gold);
        font-weight: 700;
        margin-bottom: 3px;
      }
      .info-value {
        font-family: "Cinzel", serif;
        font-size: 0.95rem;
        color: var(--warm-cream);
        font-weight: 600;
      }
      .info-value small {
        display: block;
        font-family: "Lato", sans-serif;
        font-size: 0.78rem;
        color: rgba(253, 243, 227, 0.45);
        font-weight: 300;
        margin-top: 2px;
        letter-spacing: 0;
      }

      /* Social row */
      .social-row {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
      }

      .social-label {
        font-size: 0.75rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--gold);
        font-weight: 700;
        margin-right: 4px;
      }

      .social-btn {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        text-decoration: none;
        transition:
          transform 0.3s,
          box-shadow 0.3s;
        border: 1px solid rgba(201, 149, 42, 0.3);
      }

      .social-btn.insta {
        background: linear-gradient(135deg, #833ab4, #fd1d1d, #fcb045);
        color: #fff;
      }
      .social-btn.whatsapp {
        background: #25d366;
        color: #fff;
      }
      .social-btn.youtube {
        background: #ff0000;
        color: #fff;
      }
      .social-btn.facebook {
        background: #1877f2;
        color: #fff;
      }

      .social-btn:hover {
        transform: translateY(-4px) scale(1.1);
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.4);
      }

      /* ── MAP PLACEHOLDER ── */
      .map-section {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 20px 80px;
      }

      .map-header {
        text-align: center;
        margin-bottom: 30px;
      }

      .map-wrapper {
        border-radius: 20px;
        overflow: hidden;
        border: 1px solid rgba(201, 149, 42, 0.25);
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
        position: relative;
        height: 340px;
        background:
          linear-gradient(rgba(26, 14, 5, 0.4), rgba(26, 14, 5, 0.4)),
          url("https://images.unsplash.com/photo-1524661135-423995f22d0b?w=1200&q=80")
            center/cover no-repeat;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .map-pin-badge {
        background: linear-gradient(135deg, var(--gold-dark), var(--gold));
        color: var(--deep-brown);
        padding: 14px 28px;
        border-radius: 50px;
        font-family: "Cinzel", serif;
        font-weight: 700;
        font-size: 1rem;
        display: flex;
        align-items: center;
        gap: 10px;
        box-shadow: 0 10px 40px rgba(201, 149, 42, 0.4);
        animation: float 3s ease-in-out infinite;
      }

      @keyframes float {
        0%,
        100% {
          transform: translateY(0);
        }
        50% {
          transform: translateY(-10px);
        }
      }

      /* ── TRUST BADGES ── */
      .trust-bar {
        background: linear-gradient(
          90deg,
          #0a3a64,
          rgba(10, 58, 100, 0.9),
          #0a3a64
        );
        border-top: 1px solid rgba(96, 200, 245, 0.15);
        border-bottom: 1px solid rgba(96, 200, 245, 0.15);
        padding: 30px 20px;
      }

      .trust-inner {
        max-width: 900px;
        margin: 0 auto;
        display: flex;
        justify-content: space-around;
        flex-wrap: wrap;
        gap: 24px;
      }

      .trust-item {
        text-align: center;
        flex: 1 1 150px;
      }

      .trust-num {
        font-family: "Cinzel Decorative", cursive;
        font-size: 2rem;
        font-weight: 900;
        color: #2bb5f5;
        line-height: 1;
        margin-bottom: 4px;
      }

      .trust-label {
        font-size: 0.75rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.5);
      }

      /* ── RESPONSIVE ── */
      @media (max-width: 900px) {
        .main {
          grid-template-columns: 1fr;
          gap: 40px;
        }
        .info-panel {
          order: -1;
        }
      }

      @media (max-width: 600px) {
        .form-row {
          grid-template-columns: 1fr;
        }
        .form-card {
          padding: 30px 22px;
        }
        .quick-item {
          padding: 14px 16px;
          flex: 1 1 140px;
        }
        .hero h1 {
          font-size: 2rem;
        }
        .dham-mosaic {
          grid-template-rows: 130px 130px;
        }
      }

      /* ── SCROLL FADE IN ── */
      .fade-in {
        opacity: 0;
        transform: translateY(30px);
        transition:
          opacity 0.7s ease,
          transform 0.7s ease;
      }
      .fade-in.visible {
        opacity: 1;
        transform: translateY(0);
      }

      /* input icon hack: put icon after input in DOM for focus selector */
      .input-wrap {
        display: flex;
        flex-direction: column;
        position: relative;
      }
      .input-wrap input,
      .input-wrap select,
      .input-wrap textarea {
        order: 1;
      }
      .input-wrap .fi {
        order: 0;
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: rgba(201, 149, 42, 0.5);
        font-size: 0.95rem;
        pointer-events: none;
        z-index: 1;
      }
      .input-wrap.ta .fi {
        top: 15px;
        transform: none;
      }
    </style>
  </head>

