<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>

<title>Manage Testimonials</title>

<link
rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
/>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
padding:30px;
min-height:100vh;
background:
linear-gradient(rgba(6,36,62,.94),rgba(6,36,62,.94)),
url("/assets/img/banner1.jpg") center/cover no-repeat;
}

.topbar{
display:flex;
justify-content:space-between;
align-items:center;
background:rgba(255,255,255,.12);
padding:18px 24px;
border-radius:18px;
backdrop-filter:blur(12px);
margin-bottom:25px;
}

.topbar h1{
color:#fff;
}

.back-btn{
background:#fff;
color:#0d6efd;
padding:10px 16px;
border-radius:8px;
text-decoration:none;
font-weight:bold;
}

.card{
background:rgba(255,255,255,.12);
padding:24px;
border-radius:18px;
backdrop-filter:blur(12px);
margin-bottom:18px;
color:#fff;
}

input,
textarea{
width:100%;
padding:12px;
border:none;
border-radius:10px;
margin-bottom:12px;
font-size:15px;
}

textarea{
min-height:110px;
resize:vertical;
}

button{
padding:10px 16px;
border:none;
border-radius:8px;
background:#0d6efd;
color:#fff;
cursor:pointer;
font-weight:bold;
}

.delete-btn{
background:#dc3545;
margin-top:12px;
}
</style>
</head>

<body>

<div class="topbar">

<h1>Manage Testimonials</h1>

<a
href="/admin/dashboard"
class="back-btn"
>
<i class="fa-solid fa-arrow-left"></i>
Dashboard
</a>

</div>

<form
action="/admin/testimonial/add"
method="POST"
class="card"
>

<input
type="text"
name="name"
placeholder="Customer name"
required
>

<textarea
name="message"
placeholder="Customer review"
required
></textarea>

<button type="submit">

<i class="fa-solid fa-plus"></i>

Add Testimonial

</button>

</form>

<% testimonials.forEach(item => { %>

<div class="card">

<h3><%= item.name %></h3>

<p style="margin-top:10px;">
<%= item.message %>
</p>

<form
action="/admin/testimonial/delete/<%= item._id %>"
method="POST"
>

<button
type="submit"
class="delete-btn"
>
Delete
</button>

</form>

</div>

<% }) %>

</body>
</html>