  <style>

    :root {
      --blue1: #1e90e8;
      --blue2: #2bb5f5;
      --blue3: #0d5fa8;
     
      --accent: #60c8f5;
      --white: #ffffff;
    }

    * {
  font-family: "Poppins", sans-serif !important;
}

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      font-family: 'Lato', sans-serif;
      background: #ffffff;
      color: var(--white);
      overflow-x: hidden;
    }

    /* ── HERO ── */
    .hero {
      position: relative;
      min-height: 400px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 80px 20px 70px;
      overflow: hidden;
    }

    .hero::before {
  content: "";
  position: absolute;
  inset: 0;
  background: 
    linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)),
    url("assets/img/banner1.jpg") center/cover no-repeat;
  z-index: 0;
}

    .hero-circle1 {
      position: absolute;
      width: 500px; height: 500px;
      border-radius: 50%;
      border: 1px solid rgba(255,255,255,0.08);
      top: -200px; right: -150px;
      z-index: 0;
    }

    .hero-circle2 {
      position: absolute;
      width: 300px; height: 300px;
      border-radius: 50%;
      border: 1px solid rgba(255,255,255,0.06);
      bottom: -100px; left: -80px;
      z-index: 0;
    }

    .hero-content { position: relative; z-index: 2; }

    .brand-badge {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: rgba(255,255,255,0.15);
      border: 1px solid rgba(255,255,255,0.35);
      border-radius: 40px;
      padding: 8px 22px;
      font-family: 'Cinzel', serif;
      font-size: 0.78rem;
      letter-spacing: 0.18em;
      color: #fff;
      text-transform: uppercase;
      margin-bottom: 20px;
      backdrop-filter: blur(8px);
    }

    .hero h1 {
      font-family: 'Cinzel Decorative', cursive;
      font-size: clamp(2rem, 6vw, 3.8rem);
      font-weight: 900;
      color: #fff;
      text-shadow: 0 2px 20px rgba(0,0,0,0.15);
      margin-bottom: 14px;
      line-height: 1.15;
    }

    .hero-sub {
      font-family: 'Cinzel', serif;
      font-size: clamp(0.85rem, 2vw, 1.05rem);
      color: rgba(255,255,255,0.85);
      letter-spacing: 0.1em;
      max-width: 600px;
      margin: 0 auto 28px;
    }

    .hero-tags {
      display: flex;
      gap: 10px;
      justify-content: center;
      flex-wrap: wrap;
    }

    .hero-tag {
      background: rgba(255,255,255,0.12);
      border: 1px solid rgba(255,255,255,0.25);
      border-radius: 30px;
      padding: 6px 16px;
      font-size: 0.78rem;
      font-family: 'Cinzel', serif;
      letter-spacing: 0.08em;
      color: #fff;
      backdrop-filter: blur(6px);
      transition: background 0.3s;
    }
    .hero-tag:hover { background: rgba(255,255,255,0.22); }

    /* ── FILTER BAR ── */
    .filter-bar {
      background: linear-gradient(90deg, #0d5fa8, #1a7dd4, #0d5fa8);
      padding: 0;
      overflow: hidden;
      border-bottom: 1px solid rgba(96,200,245,0.2);
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .filter-inner {
      max-width: 1100px;
      margin: 0 auto;
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
    }

    .filter-btn {
      padding: 16px 24px;
      background: none;
      border: none;
      border-bottom: 3px solid transparent;
      color: rgba(255,255,255,0.6);
      font-family: 'Cinzel', serif;
      font-size: 0.8rem;
      letter-spacing: 0.08em;
      cursor: pointer;
      transition: all 0.3s;
      white-space: nowrap;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .filter-btn:hover, .filter-btn.active {
      color: #fff;
      border-bottom-color: var(--accent);
      background: rgba(255,255,255,0.08);
    }

    /* ── SECTIONS ── */
    .section {
      background: var(--dark);
      padding: 70px 20px;
    }

    .section-alt { background: #061e35; }

    .section-header {
      text-align: center;
      margin-bottom: 50px;
    }

    .section-header h2 {
      font-family: 'Cinzel', serif;
      font-size: clamp(1.5rem, 4vw, 2.2rem);
      font-weight: 700;
      color: var(--accent);
      margin-bottom: 10px;
    }

    .section-header p {
      color: rgba(255,255,255,0.5);
      font-size: 0.95rem;
      max-width: 520px;
      margin: 0 auto;
    }

    .divider {
      display: flex;
      align-items: center;
      gap: 12px;
      justify-content: center;
      margin-top: 14px;
    }
    .divider span {
      height: 1px; width: 60px;
      background: linear-gradient(to right, transparent, var(--accent));
    }
    .divider span:last-child { background: linear-gradient(to left, transparent, var(--accent)); }
    .divider i { color: var(--accent); font-size: 1rem; }

    /* ── FEATURED ACTIVITY (BIG HERO CARD) ── */
    .featured-wrap {
      max-width: 1200px;
      margin: 0 auto 60px;
    }

    .featured-card {
      border-radius: 24px;
      overflow: hidden;
      position: relative;
      height: 420px;
      border: 1px solid rgba(96,200,245,0.25);
      box-shadow: 0 20px 60px rgba(0,0,0,0.5);
    }

    .featured-card img {
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform 0.6s;
    }

    .featured-card:hover img { transform: scale(1.04); }

    .featured-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to right, rgba(6,36,62,0.92) 40%, rgba(6,36,62,0.3) 100%);
    }

    .featured-body {
      position: absolute;
      top: 50%; left: 0;
      transform: translateY(-50%);
      padding: 0 50px;
      max-width: 560px;
    }

    .feat-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: linear-gradient(135deg, var(--blue3), var(--blue1));
      color: #fff;
      font-family: 'Cinzel', serif;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      padding: 6px 16px;
      border-radius: 20px;
      margin-bottom: 16px;
    }

    .featured-body h3 {
      font-family: 'Cinzel Decorative', cursive;
      font-size: clamp(1.4rem, 4vw, 2.2rem);
      font-weight: 900;
      color: #fff;
      margin-bottom: 12px;
      line-height: 1.2;
    }

    .featured-body p {
      font-size: 0.95rem;
      color: rgba(255,255,255,0.7);
      line-height: 1.7;
      margin-bottom: 22px;
    }

    .feat-meta {
      display: flex;
      gap: 20px;
      flex-wrap: wrap;
      margin-bottom: 24px;
    }

    .feat-meta-item {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 0.85rem;
      color: rgba(255,255,255,0.65);
    }

    .feat-meta-item i { color: var(--accent); }

    .feat-btn {
      background: linear-gradient(135deg, var(--blue3), var(--blue1));
      color: #fff;
      border: none;
      padding: 13px 28px;
      border-radius: 12px;
      font-family: 'Cinzel', serif;
      font-size: 0.9rem;
      font-weight: 700;
      cursor: pointer;
      letter-spacing: 0.08em;
      transition: all 0.3s;
      box-shadow: 0 6px 25px rgba(30,144,232,0.4);
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 10px;
    }

    .feat-btn:hover {
      transform: translateY(-3px);
      box-shadow: 0 12px 35px rgba(30,144,232,0.55);
    }

    /* ── ACTIVITY CARDS GRID ── */
    .activities-grid {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 24px;
    }

    .act-card {
      background: linear-gradient(145deg, rgba(10,58,100,0.85), rgba(6,36,62,0.95));
      border: 1px solid rgba(96,200,245,0.18);
      border-radius: 18px;
      overflow: hidden;
      transition: transform 0.35s, box-shadow 0.35s, border-color 0.35s;
      position: relative;
    }

    .act-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 20px 55px rgba(30,144,232,0.22);
      border-color: var(--accent);
    }

    .act-img-wrap { position: relative; overflow: hidden; }

    .act-img {
      width: 100%;
      height: 200px;
      object-fit: cover;
      display: block;
      transition: transform 0.5s;
    }

    .act-card:hover .act-img { transform: scale(1.06); }

    .act-img-overlay {
      position: absolute; bottom: 0; left: 0; right: 0;
      height: 70px;
      background: linear-gradient(to top, rgba(6,36,62,0.95), transparent);
    }

    .act-cat-badge {
      position: absolute;
      top: 14px; left: 14px;
      background: rgba(13,95,168,0.9);
      backdrop-filter: blur(6px);
      border: 1px solid rgba(96,200,245,0.3);
      color: #fff;
      font-family: 'Cinzel', serif;
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      padding: 5px 12px;
      border-radius: 20px;
    }

    .act-diff {
      position: absolute;
      top: 14px; right: 14px;
      width: 32px; height: 32px;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 0.7rem;
      font-weight: 700;
      font-family: 'Cinzel', serif;
    }

    .act-diff.easy { background: rgba(34,197,94,0.85); color: #fff; }
    .act-diff.mod  { background: rgba(251,146,60,0.85); color: #fff; }
    .act-diff.hard { background: rgba(239,68,68,0.85);  color: #fff; }

    .act-body { padding: 20px; }

    .act-icon {
      width: 44px; height: 44px;
      background: linear-gradient(135deg, var(--blue3), var(--blue1));
      border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.1rem;
      color: #fff;
      margin-bottom: 12px;
      box-shadow: 0 4px 14px rgba(30,144,232,0.3);
    }

    .act-title {
      font-family: 'Cinzel', serif;
      font-size: 1.05rem;
      font-weight: 700;
      color: #fff;
      margin-bottom: 8px;
    }

    .act-desc {
      font-size: 0.87rem;
      color: rgba(255,255,255,0.55);
      line-height: 1.65;
      margin-bottom: 16px;
    }

    .act-meta {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
      margin-bottom: 16px;
    }

    .act-meta-item {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 0.78rem;
      color: rgba(255,255,255,0.5);
    }

    .act-meta-item i { color: var(--blue2); font-size: 0.75rem; }

    .act-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-top: 14px;
      border-top: 1px solid rgba(96,200,245,0.12);
      gap: 10px;
      flex-wrap: wrap;
    }

    .act-price {
      font-family: 'Cinzel', serif;
    }
    .act-price .from { font-size: 0.65rem; color: rgba(255,255,255,0.35); display: block; }
    .act-price .amt  { font-size: 1.1rem; font-weight: 700; color: #fff; }
    .act-price .pp   { font-size: 0.65rem; color: rgba(255,255,255,0.35); }

    .act-btn {
      background: linear-gradient(135deg, var(--blue3), var(--blue1));
      color: #fff;
      border: none;
      padding: 9px 18px;
      border-radius: 9px;
      font-family: 'Cinzel', serif;
      font-size: 0.75rem;
      font-weight: 700;
      cursor: pointer;
      letter-spacing: 0.06em;
      transition: all 0.3s;
      box-shadow: 0 3px 12px rgba(30,144,232,0.28);
      text-decoration: none;
      display: inline-block;
    }

    .act-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 7px 22px rgba(30,144,232,0.45);
    }

    /* ── EXPERIENCE TIMELINE ── */
    .timeline-wrap {
      max-width: 900px;
      margin: 0 auto;
      position: relative;
    }

    .timeline-wrap::before {
      content: '';
      position: absolute;
      left: 50%;
      top: 0; bottom: 0;
      width: 2px;
      background: linear-gradient(to bottom, transparent, var(--blue2), var(--blue1), transparent);
      transform: translateX(-50%);
    }

    .tl-item {
      display: grid;
      grid-template-columns: 1fr 60px 1fr;
      gap: 0;
      margin-bottom: 40px;
      align-items: center;
    }

    .tl-item:nth-child(odd) .tl-content { grid-column: 1; text-align: right; padding-right: 30px; }
    .tl-item:nth-child(odd) .tl-empty   { grid-column: 3; }
    .tl-item:nth-child(even) .tl-content{ grid-column: 3; text-align: left; padding-left: 30px; }
    .tl-item:nth-child(even) .tl-empty  { grid-column: 1; }

    .tl-dot {
      grid-column: 2;
      width: 50px; height: 50px;
      background: linear-gradient(135deg, var(--blue3), var(--blue1));
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.1rem;
      color: #fff;
      margin: 0 auto;
      box-shadow: 0 0 0 4px rgba(30,144,232,0.2), 0 4px 15px rgba(30,144,232,0.3);
      z-index: 1;
      position: relative;
    }

    .tl-content {
      background: linear-gradient(135deg, rgba(10,58,100,0.8), rgba(6,36,62,0.9));
      border: 1px solid rgba(96,200,245,0.18);
      border-radius: 14px;
      padding: 20px 22px;
      transition: border-color 0.3s;
    }

    .tl-content:hover { border-color: var(--accent); }

    .tl-day {
      font-size: 0.68rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent);
      font-weight: 700;
      margin-bottom: 4px;
    }

    .tl-title {
      font-family: 'Cinzel', serif;
      font-size: 1rem;
      font-weight: 700;
      color: #fff;
      margin-bottom: 6px;
    }

    .tl-desc {
      font-size: 0.83rem;
      color: rgba(255,255,255,0.5);
      line-height: 1.6;
    }

    /* ── GALLERY MOSAIC ── */
    .gallery-grid {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      grid-template-rows: 220px 220px;
      gap: 12px;
    }

    .gal-item {
      border-radius: 14px;
      overflow: hidden;
      position: relative;
      cursor: pointer;
    }

    .gal-item.tall { grid-row: span 2; }
    .gal-item.wide { grid-column: span 2; }

    .gal-item img {
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform 0.5s;
      display: block;
    }

    .gal-item:hover img { transform: scale(1.07); }

    .gal-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(6,36,62,0.7) 0%, transparent 60%);
      opacity: 0;
      transition: opacity 0.3s;
      display: flex;
      align-items: flex-end;
      padding: 16px;
    }

    .gal-item:hover .gal-overlay { opacity: 1; }

    .gal-label {
      font-family: 'Cinzel', serif;
      font-size: 0.88rem;
      font-weight: 700;
      color: #fff;
    }

    /* ── WHY CHOOSE US ── */
    .why-grid {
      max-width: 1100px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 20px;
    }

    .why-card {
      background: linear-gradient(145deg, rgba(10,58,100,0.8), rgba(6,36,62,0.9));
      border: 1px solid rgba(96,200,245,0.15);
      border-radius: 18px;
      padding: 30px 24px;
      text-align: center;
      transition: transform 0.35s, border-color 0.3s, box-shadow 0.35s;
    }

    .why-card:hover {
      transform: translateY(-6px);
      border-color: var(--accent);
      box-shadow: 0 15px 40px rgba(30,144,232,0.2);
    }

    .why-icon {
      width: 60px; height: 60px;
      background: linear-gradient(135deg, var(--blue3), var(--blue1));
      border-radius: 18px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.4rem;
      color: #fff;
      margin: 0 auto 16px;
      box-shadow: 0 6px 20px rgba(30,144,232,0.35);
    }

    .why-title {
      font-family: 'Cinzel', serif;
      font-size: 0.95rem;
      font-weight: 700;
      color: #fff;
      margin-bottom: 8px;
    }

    .why-desc {
      font-size: 0.82rem;
      color: rgba(255,255,255,0.5);
      line-height: 1.65;
    }

    /* ── CTA BANNER ── */
    .cta-banner {
      background: linear-gradient(135deg, #1e90e8 0%, #2bb5f5 50%, #0d5fa8 100%);
      padding: 60px 20px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .cta-banner::before {
      content: '';
      position: absolute;
      width: 400px; height: 400px;
      border-radius: 50%;
      border: 1px solid rgba(255,255,255,0.1);
      top: -150px; right: -100px;
    }

    .cta-banner::after {
      content: '';
      position: absolute;
      width: 300px; height: 300px;
      border-radius: 50%;
      border: 1px solid rgba(255,255,255,0.08);
      bottom: -120px; left: -80px;
    }

    .cta-inner { position: relative; z-index: 1; max-width: 700px; margin: 0 auto; }

    .cta-banner h2 {
      font-family: 'Cinzel Decorative', cursive;
      font-size: clamp(1.5rem, 4vw, 2.4rem);
      font-weight: 900;
      color: #fff;
      margin-bottom: 12px;
    }

    .cta-banner p {
      font-family: 'Cinzel', serif;
      font-size: 1rem;
      color: rgba(255,255,255,0.8);
      margin-bottom: 32px;
      letter-spacing: 0.06em;
    }

    .cta-btns {
      display: flex;
      gap: 14px;
      justify-content: center;
      flex-wrap: wrap;
    }

    .cta-btn {
      padding: 14px 28px;
      border-radius: 12px;
      font-family: 'Cinzel', serif;
      font-size: 0.9rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      cursor: pointer;
      transition: all 0.3s;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
      border: none;
    }

    .cta-btn.solid {
      background: #fff;
      color: var(--blue3);
      box-shadow: 0 6px 25px rgba(0,0,0,0.2);
    }

    .cta-btn.solid:hover {
      transform: translateY(-3px);
      box-shadow: 0 12px 35px rgba(0,0,0,0.3);
    }

    .cta-btn.outline {
      background: transparent;
      color: #fff;
      border: 2px solid rgba(255,255,255,0.5);
    }

    .cta-btn.outline:hover {
      border-color: #fff;
      background: rgba(255,255,255,0.12);
    }

    /* ── SCROLL FADE ── */
    .fade-in {
      opacity: 0;
      transform: translateY(26px);
      transition: opacity 0.65s ease, transform 0.65s ease;
    }
    .fade-in.visible { opacity: 1; transform: translateY(0); }

    /* ── RESPONSIVE ── */
    @media (max-width: 900px) {
      .gallery-grid { grid-template-columns: 1fr 1fr; grid-template-rows: auto; }
      .gal-item.tall  { grid-row: span 1; }
      .gal-item.wide  { grid-column: span 2; }
      .timeline-wrap::before { left: 24px; }
      .tl-item { grid-template-columns: 50px 1fr; gap: 16px; }
      .tl-item:nth-child(odd) .tl-content,
