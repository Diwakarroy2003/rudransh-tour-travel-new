<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>

<title>Rudransh Admin</title>

<link
rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
/>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
min-height:100vh;
padding:30px;
background:
linear-gradient(rgba(6,36,62,.92),rgba(6,36,62,.92)),
url("/assets/img/banner1.jpg") center/cover no-repeat;
}

.topbar{
display:flex;
justify-content:space-between;
align-items:center;
padding:20px 28px;
border-radius:18px;
background:rgba(255,255,255,.12);
backdrop-filter:blur(14px);
box-shadow:0 8px 25px rgba(0,0,0,.25);
margin-bottom:35px;
}

.topbar h1{
color:#fff;
font-size:28px;
}

.topbar span{
display:block;
font-size:13px;
color:#cde8ff;
margin-top:5px;
}

.logout-btn{
background:#ff4d4d;
color:white;
padding:10px 18px;
border-radius:10px;
text-decoration:none;
font-weight:bold;
}

.logout-btn:hover{
transform:translateY(-2px);
}

.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
gap:22px;
}

.card{
background:rgba(255,255,255,.12);
border:1px solid rgba(255,255,255,.15);
border-radius:20px;
padding:28px;
backdrop-filter:blur(14px);
transition:.3s;
box-shadow:0 10px 25px rgba(0,0,0,.18);
}

.card:hover{
transform:translateY(-8px);
box-shadow:0 18px 35px rgba(0,0,0,.28);
}

.icon{
width:58px;
height:58px;
border-radius:14px;
display:flex;
align-items:center;
justify-content:center;
font-size:24px;
color:#fff;
margin-bottom:18px;
}

.blue{
background:linear-gradient(135deg,#0d6efd,#42b3ff);
}

.green{
background:linear-gradient(135deg,#28a745,#52d67b);
}

.orange{
background:linear-gradient(135deg,#ff9800,#ffb74d);
}

.purple{
background:linear-gradient(135deg,#8e44ad,#b36ae2);
}

.card h3{
color:#fff;
margin-bottom:10px;
font-size:22px;
}

.card p{
color:#d9ecff;
font-size:14px;
margin-bottom:18px;
line-height:1.5;
}

.card a{
display:inline-block;
text-decoration:none;
background:#fff;
color:#0d6efd;
padding:10px 16px;
border-radius:8px;
font-weight:bold;
}

.card a:hover{
opacity:.95;
}
</style>
</head>

<body>

<div class="topbar">

<div>
<h1>Rudransh Tours Admin</h1>
<span>Manage bookings, packages & website content</span>
</div>

<a href="/admin/logout" class="logout-btn">
<i class="fa-solid fa-right-from-bracket"></i>
Logout
</a>

</div>

<div class="grid">

<div class="card">
<div class="icon blue">
<i class="fa-solid fa-envelope"></i>
</div>

<h3>Enquiries</h3>

<p>
Check customer bookings and travel enquiries.
</p>

<a href="/admin/enquiries">
Open Enquiries
</a>
</div>

<div class="card">
<div class="icon green">
<i class="fa-solid fa-image"></i>
</div>

<h3>Gallery</h3>

<p>
Upload and manage travel photos.
</p>

<a href="/admin/gallery">
Manage Gallery
</a>
</div>

<div class="card">
<div class="icon orange">
<i class="fa-solid fa-box-open"></i>
</div>

<h3>Packages</h3>

<p>
Create or update yatra packages.
</p>

<a href="/admin/package">
Manage Packages
</a>
</div>

<div class="card">
<div class="icon purple">
<i class="fa-solid fa-star"></i>
</div>

<h3>Testimonials</h3>

<p>
View and manage customer reviews.
</p>

<a href="/admin/testimonial">
Manage Reviews
</a>
</div>

</div>

</body>
</html>