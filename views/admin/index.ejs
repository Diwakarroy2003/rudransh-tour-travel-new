    <style>
/* SECTION */
.iv-yatra-section {
  padding: 40px 20px;
  background: #f5f7fa;
}

/* GRID */
.iv-container {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
}

/* CARD */
.iv-card {
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  height: 100%;
  box-shadow: 0 4px 10px rgba(0,0,0,0.08);
  transition: transform 0.3s ease;
}

.iv-card:hover {
  transform: translateY(-6px);
}

/* IMAGE (NO CROP) */
.iv-card img {
  width: 100%;
  height: 200px;
  object-fit: contain;
  background: #f0f0f0;
  transition: transform 0.4s ease;
}

/* IMAGE HOVER */
.iv-card:hover img {
  transform: scale(1.05);
}

/* BODY */
.iv-card-body {
  padding: 15px;
  display: flex;
  flex-direction: column;
  flex-grow: 1;
}

.iv-days {
  color: #e63946;
  font-weight: 600;
}

.iv-card-body ul {
  padding-left: 18px;
  margin: 10px 0;
}

/* PRICE */
.iv-card-body h4 {
  color: green;
  margin-top: auto;
}

/* BUTTON */
.iv-btn {
  margin-top: 12px;
  padding: 10px;
  text-align: center;
  background: #2a6fdb;
  color: #fff;
  border-radius: 6px;
  text-decoration: none;
  font-weight: 500;
  transition: all 0.3s ease;
}

/* BUTTON HOVER */
.iv-btn:hover {
  background: #1d4ed8;
  transform: scale(1.05);
}

/* RESPONSIVE */
@media (max-width: 1024px) {
  .iv-container {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 576px) {
  .iv-container {
    grid-template-columns: 1fr;
  }

  .iv-card img {
    height: 180px;
  }
}






/* ===== TOUR SECTION ===== */

.x-tour-section{
  padding:50px 20px;
}

.x-gap{
  margin-top:50px;
}

/* 🔥 MAIN FIX */
.x-tour-flex{
  display:flex;
  gap:25px;
  align-items:stretch; /* 👈 CHANGE (center → stretch) */
}

.x-reverse{
  flex-direction:row-reverse;
}

.x-tour-img,
.x-tour-content{
  flex:1;
}

/* 🔥 REMOVE FIXED HEIGHT */
.x-tour-img{
  /* height:360px; ❌ REMOVE */
  overflow:hidden;
  border-radius:12px;
  display:flex;
}

/* IMAGE FULL HEIGHT */
.x-tour-img img{
  width:100%;
  height:100%;
  object-fit:cover;
  transition:transform 0.5s ease;
}

.x-tour-content{
  background:#fff;
  padding:20px;
  border-radius:12px;
  display:flex;
  flex-direction:column;
  gap:15px;
  box-shadow:0 5px 15px rgba(0,0,0,0.05);
  transition:all 0.3s ease;
}

.x-features{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:10px;
}

.x-features div{
  background:#f9f9f9;
  padding:10px;
  border-radius:8px;
  transition:0.3s;
}

.x-price-box{
  display:flex;
  gap:10px;
}

.x-price-box div{
  flex:1;
  background:#f4b400;
  padding:12px;
  border-radius:8px;
  text-align:center;
  font-weight:bold;
}

.x-btn-wrap{
  display:flex;
  justify-content:center;
}

.x-btn{
  padding:12px 25px;
  background:black;
  color:white;
  border:none;
  border-radius:6px;
  cursor:pointer;
  transition:0.3s;
}

/* ===== VEHICLES ===== */

.x-vehicle-section{
  padding:50px 20px;
  background:#f5f7fa;
}

.x-title{
  text-align:center;
  margin-bottom:30px;
}

.x-vehicle-container{
  max-width:1200px;
  margin:auto;
}

.x-vehicle-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:25px;
}

.x-vehicle{
  background:#fff;
  border-radius:14px;
  overflow:hidden;
  box-shadow:0 5px 15px rgba(0,0,0,0.08);
  transition:0.3s;
}

.x-vehicle img{
  width:100%;
  height:200px;
  object-fit:cover;
  transition:0.4s;
}

.x-vehicle h3{
  text-align:center;
  margin:15px 0;
}

.x-vehicle button{
  display:block;
  margin:0 auto 15px;
  padding:10px 20px;
  background:#f4b400;
  border:none;
  border-radius:6px;
  cursor:pointer;
  transition:0.3s;
}

/* ===== HOVER ===== */

.x-tour-img:hover img{
  transform:scale(1.08);
}

.x-tour-content:hover{
  transform:translateY(-5px);
  box-shadow:0 15px 30px rgba(0,0,0,0.12);
}

.x-features div:hover{
  transform:translateY(-3px);
  background:#fff;
  box-shadow:0 10px 20px rgba(0,0,0,0.1);
}

.x-btn:hover{
  background:#f4b400;
  color:#000;
}

.x-vehicle:hover{
  transform:translateY(-8px);
  box-shadow:0 15px 30px rgba(0,0,0,0.15);
}

.x-vehicle:hover img{
  transform:scale(1.08);
}

.x-vehicle button:hover{
  background:#000;
  color:#fff;
}

/* ===== MOBILE ===== */

@media(max-width:768px){
  .x-tour-flex{
    flex-direction:column;
  }

  .x-features{
    grid-template-columns:1fr;
  }

  .x-price-box{
    flex-direction:column;
  }

  /* mobile me fixed height theek hai */
  .x-tour-img{
    height:250px;
  }

  .x-vehicle-grid{
    grid-template-columns:1fr;
  }
}

.x-tour-img img{
  object-fit: cover;
  object-position: center top; /* 👈 ADD THIS */
}


