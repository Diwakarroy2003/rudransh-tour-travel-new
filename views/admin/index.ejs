<div class="container mb-100">

    <div class="section-title text-center mb-5">
        <h2>Traveler Reviews</h2>
        <p>Share your experience with us</p>
    </div>

    <!-- Review Form -->
    <div class="row mb-5">
        <div class="col-lg-8 mx-auto">

            <div
                style="
                    background:#fff;
                    padding:35px;
                    border-radius:18px;
                    box-shadow:0 10px 30px rgba(0,0,0,0.08);
                "
            >

                <form action="/testimonial" method="POST">

                    <div class="row">

                        <div class="col-md-6 mb-3">
                            <label
                                style="
                                    font-weight:600;
                                    margin-bottom:8px;
                                "
                            >
                                Full Name
                            </label>

                            <input
                                type="text"
                                name="name"
                                class="form-control"
                                placeholder="Enter your name"
                                required
                                style="
                                    height:52px;
                                    border-radius:10px;
                                "
                            >
                        </div>

                        <div class="col-md-6 mb-3">
                            <label
                                style="
                                    font-weight:600;
                                    margin-bottom:8px;
                                "
                            >
                                City / State
                            </label>

                            <input
                                type="text"
                                name="city"
                                class="form-control"
                                placeholder="Patna, Bihar"
                                required
                                style="
                                    height:52px;
                                    border-radius:10px;
                                "
                            >
                        </div>

                        <div class="col-md-6 mb-3">
                            <label
                                style="
                                    font-weight:600;
                                    margin-bottom:8px;
                                "
                            >
                                Rating
                            </label>

                            <select
                                name="rating"
                                class="form-control"
                                required
                                style="
                                    height:52px;
                                    border-radius:10px;
                                "
                            >
                                <option value="">Select Rating</option>
                                <option>⭐⭐⭐⭐⭐ Excellent</option>
                                <option>⭐⭐⭐⭐ Very Good</option>
                                <option>⭐⭐⭐ Good</option>
                                <option>⭐⭐ Average</option>
                                <option>⭐ Poor</option>
                            </select>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label
                                style="
                                    font-weight:600;
                                    margin-bottom:8px;
                                "
                            >
                                Destination / Package
                            </label>

                            <input
                                type="text"
                                name="package"
                                class="form-control"
                                placeholder="Char Dham / Kedarnath"
                                style="
                                    height:52px;
                                    border-radius:10px;
                                "
                            >
                        </div>

                        <div class="col-12 mb-4">
                            <label
                                style="
                                    font-weight:600;
                                    margin-bottom:8px;
                                "
                            >
                                Your Review
                            </label>

                            <textarea
                                name="message"
                                class="form-control"
                                rows="5"
                                placeholder="Share your experience with Rudransh Tours & Travels"
                                required
                                style="border-radius:10px;"
                            ></textarea>
                        </div>

                        <div class="col-12 text-center">

                            <button
                                type="submit"
                                class="primary-btn1 black-bg"
                                style="
                                    min-width:220px;
                                    border-radius:12px;
                                    padding:14px 28px;
                                "
                            >
                                Submit Review
                            </button>

                        </div>

                    </div>

                </form>

            </div>

        </div>
    </div>

    <!-- Dynamic Reviews -->
    <div class="row">

        <% testimonials.forEach(function(item){ %>

            <div class="col-lg-4 mb-4">

                <div
                    style="
                        background:#fff;
                        padding:25px;
                        border-radius:15px;
                        box-shadow:0 6px 18px rgba(0,0,0,0.08);
                        height:100%;
                    "
                >

                    <h5
                        style="
                            font-weight:700;
                            margin-bottom:10px;
                        "
                    >
                        <%= item.name %>
                    </h5>

                    <p style="margin-bottom:6px;">
                        <strong><%= item.city %></strong>
                    </p>

                    <p style="margin-bottom:6px;">
                        <%= item.rating %>
                    </p>

                    <p style="margin-bottom:10px;">
                        <strong><%= item.package %></strong>
                    </p>

                    <p style="margin:0;">
                        <%= item.message %>
                    </p>

                </div>

            </div>

        <% }) %>

    </div>

</div>

